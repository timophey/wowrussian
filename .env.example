# Application
APP_NAME=WowRussian Analyzer
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# Choose one of the following:
#
# SQLite (default, good for development):
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
#
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://wowrussian:wowrussian_password@postgres:5432/wowrussian
#
# MySQL/MariaDB (alternative for production):
# DATABASE_URL=mysql+aiomysql://wowrussian:wowrussian_password@mysql:3306/wowrussian
#
# For local development without Docker, use:
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/wowrussian
# MySQL: mysql+aiomysql://user:password@localhost:3306/wowrussian
#
# Default (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATABASE_URL=postgresql+asyncpg://wowrussian:wowrussian_password@postgres:5432/wowrussian


# PostgreSQL credentials (used in docker-compose)
POSTGRES_USER=wowrussian
POSTGRES_PASSWORD=wowrussian_password
POSTGRES_DB=wowrussian

# MySQL credentials (used in docker-compose)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=wowrussian
MYSQL_USER=wowrussian
MYSQL_PASSWORD=wowrussian_password

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Storage
STORAGE_PATH=/app/storage
UPLOAD_MAX_SIZE=10485760

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Crawler
CRAWLER_USER_AGENT=WowRussianBot/1.0
CRAWLER_DELAY=1
CRAWLER_TIMEOUT=30
CRAWLER_MAX_PAGES=1000

# Dictionary (law №168-FZ compliance)
DICTIONARY_PATH=/app/dictionaries/russian_words.txt
DICTIONARY_URL=https://raw.githubusercontent.com/danakt/russian-words/master/russian.txt
AUTO_DOWNLOAD_DICTIONARY=True